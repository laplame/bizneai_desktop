{
  "name": "bizneai-local-api",
  "private": true,
  "version": "1.0.14",
  "description": "API local BizneAI (Express + SQLite) para ejecutar aparte del POS",
  "engines": {
    "node": ">=20 <21"
  },
  "main": "start.cjs",
  "bin": "start.cjs",
  "scripts": {
    "start": "node start.cjs"
  },
  "pkg": {
    "scripts": ["pkg-start.cjs"],
    "assets": [
      "bizneai-server.cjs",
      "node_modules/better-sqlite3/**/*",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*"
    ],
    "targets": [
      "node20-win-x64"
    ]
  },
  "dependencies": {
    "axios": "^1.7.9",
    "better-sqlite3": "^12.2.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "socket.io": "^4.8.1",
    "zod": "^4.0.10"
  }
}
