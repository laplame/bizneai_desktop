{
  "name": "bizneai",
  "private": true,
  "version": "1.0.13",
  "description": "Sistema de Punto de Venta Moderno con Tickets Virtuales",
  "author": {
    "name": "BizneAI Team",
    "email": "info@bizneai.com"
  },
  "license": "MIT",
  "type": "module",
  "main": "electron/main.js",
  "homepage": "./",
  "repository": {
    "type": "git",
    "url": "https://github.com/bizneai/pos-system.git"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/src/index.ts",
    "dev:full": "concurrently \"npm run dev\" \"wait-on tcp:localhost:5173 tcp:localhost:3000 && electron .\"",
    "build": "tsc -b && vite build",
    "build:server": "node scripts/bundle-server.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on tcp:localhost:5173 tcp:localhost:3000 && electron .\"",
    "electron:dev:pos": "concurrently \"npm run dev:client\" \"wait-on tcp:localhost:5173 && electron .\"",
    "start": "npm run build && npm run build:server && electron .",
    "electron:build": "npm run build && npm run build:server && electron-builder",
    "dist": "npm run bump-version && npm run build && npm run build:server && electron-builder",
    "dist:mac": "npm run bump-version && npm run fix-deps && npm run build && npm run build:server && electron-builder --mac",
    "dist:win": "npm run bump-version && npm run fix-deps && npm run build && npm run build:server && electron-builder --win",
    "dist:linux": "npm run bump-version && npm run fix-deps && npm run build && npm run build:server && electron-builder --linux",
    "pack": "npm run build && npm run build:server && electron-builder --dir",
    "pack:mac": "npm run bump-version && npm run build && npm run build:server && electron-builder --dir --mac",
    "pack:win": "npm run bump-version && npm run build && npm run build:server && electron-builder --dir --win",
    "fix-deps": "node scripts/fix-dependencies.cjs",
    "bump-version": "node scripts/bump-version.cjs",
    "start:all": "concurrently \"npm run dev\" \"wait-on tcp:localhost:5173 tcp:localhost:3000 && electron .\"",
    "generate-icons": "node scripts/generate-icons.js",
    "build-desktop": "node scripts/build-desktop.js",
    "build-desktop:mac": "npm run bump-version && npm run fix-deps && npm run build && npm run build:server && electron-builder --mac",
    "build-desktop:win": "npm run bump-version && npm run fix-deps && npm run build && npm run build:server && electron-builder --win",
    "build-desktop:linux": "npm run bump-version && npm run fix-deps && npm run build && npm run build:server && electron-builder --linux",
    "build-desktop:all": "npm run bump-version && npm run fix-deps && npm run build && npm run build:server && electron-builder -mwl",
    "build-win-simple": "node scripts/build-win-simple.js"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "better-sqlite3": "^12.2.0",
    "call-bind": "^1.0.8",
    "call-bind-apply-helpers": "^1.0.2",
    "chalk": "^5.4.1",
    "cloudinary": "^2.7.0",
    "cors": "^2.8.5",
    "electron-pos-printer": "^1.3.8",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.1.0",
    "i18next": "^25.8.13",
    "lucide-react": "^0.525.0",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "quagga": "^0.6.16",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hot-toast": "^2.5.2",
    "react-i18next": "^16.5.4",
    "socket.io": "^4.8.1",
    "sqlite3": "^5.0.2",
    "stripe": "^18.3.0",
    "swagger-jsdoc": "^1.2.1",
    "swagger-ui-express": "^5.0.1",
    "ws": "^8.18.3",
    "zod": "^4.0.10"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/chai": "^4.3.11",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "baseline-browser-mapping": "^2.10.0",
    "chai": "^4.5.0",
    "concurrently": "^8.2.2",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.0.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "jimp": "^0.22.12",
    "nodemon": "^3.1.0",
    "png-to-ico": "^2.1.2",
    "tsx": "^4.20.6",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^7.0.4",
    "wait-on": "^7.2.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "build": {
    "appId": "com.bizneai.pos",
    "productName": "BizneAI POS",
    "copyright": "Copyright © 2024 BizneAI Team",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-backend/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json",
      "!node_modules/.cache/**/*",
      "!node_modules/.vite/**/*",
      "!node_modules/.bin/**/*",
      "!node_modules/*/test/**/*",
      "!node_modules/*/tests/**/*",
      "!node_modules/*/docs/**/*",
      "!node_modules/*/examples/**/*"
    ],
    "extraResources": [
      {
        "from": "public",
        "to": "public"
      },
      {
        "from": "embedded-node",
        "to": "embedded-node",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/call-bind-apply-helpers/**/*",
      "node_modules/call-bind/**/*",
      "node_modules/get-intrinsic/**/*",
      "node_modules/side-channel/**/*",
      "node_modules/dunder-proto/**/*",
      "node_modules/get-proto/**/*",
      "node_modules/better-sqlite3/**/*",
      "node_modules/sqlite3/**/*",
      "node_modules/express/**/*",
      "node_modules/qs/**/*",
      "node_modules/cloudinary/**/*",
      "node_modules/multer/**/*",
      "node_modules/cors/**/*",
      "node_modules/helmet/**/*",
      "node_modules/morgan/**/*",
      "node_modules/socket.io/**/*",
      "node_modules/ws/**/*",
      "node_modules/axios/**/*",
      "node_modules/stripe/**/*",
      "node_modules/zod/**/*",
      "node_modules/quagga/**/*",
      "node_modules/lucide-react/**/*",
      "node_modules/react-hot-toast/**/*",
      "node_modules/electron-pos-printer/**/*"
    ],
    "nodeGypRebuild": false,
    "buildDependenciesFromSource": false,
    "npmRebuild": false,
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "darkModeSupport": true,
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BizneAI POS"
    },
    "dmg": {
      "title": "BizneAI POS Installer",
      "icon": "build/icon.icns",
      "background": "build/background.png",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "format": "ULFO"
    }
  }
}
